# ─── App ──────────────────────────────────────────────────────────────────────
APP_PORT=3005
APP_ENV=development

# ─── Database ─────────────────────────────────────────────────────────────────
# Shared runtime Postgres connection.
# api/database owns migrations and Prisma generation; this service uses runtime access only.
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# ─── JWT (shared with api/auth/ — validates user tokens issued there) ──────────
# MUST be identical to JWT_SECRET in api/auth/
JWT_SECRET=same_secret_as_auth_service_here

# ─── Encryption (shared with api/auth/ — decrypts PID/NID for exact ID search) ──
# MUST be identical to ENCRYPTION_SECRET in api/auth/
ENCRYPTION_SECRET=same_encryption_secret_as_auth_service_here

# ─── AWS S3 ───────────────────────────────────────────────────────────────────
# Same bucket — document content is stored under documents/ prefix
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your_aws_access_key
AWS_SECRET_ACCESS_KEY=your_aws_secret_key
AWS_S3_BUCKET_NAME=your_s3_bucket_name

# ─── Signature Service ────────────────────────────────────────────────────────
# Internal URL to api/signature/ — used when the document service
# needs to verify a signing operation was completed
# Note: The actual signing call is made from the FRONTEND using the user's JWT
# The documents service only records the result and locks the document
SIGNATURE_SERVICE_URL=http://localhost:3002

# ─── Document Settings ────────────────────────────────────────────────────────
# Maximum document content size in bytes (default 10MB)
MAX_CONTENT_SIZE_BYTES=10485760

# Maximum number of versions to retain per document (older ones pruned)
MAX_VERSIONS_PER_DOCUMENT=50

# Autosave version retention in days (versions older than this are pruned)
VERSION_RETENTION_DAYS=90

# ─── Editor Image Uploads ────────────────────────────────────────────────────
# Editor images are stored privately in S3 under document-editor-images/.
# Optional public API base used to generate stable image render URLs.
DOCUMENTS_API_PUBLIC_URL=http://localhost:3005/api/v1
EDITOR_IMAGE_MAX_SIZE_BYTES=8388608
# Render-token lifetime in seconds for newly uploaded editor images.
EDITOR_IMAGE_TOKEN_TTL_SECONDS=2592000

# ─── CORS ─────────────────────────────────────────────────────────────────────
# Optional additional allowed origins, comma-separated
FRONTEND_URLS=http://localhost:4000

# ─── Documents Frontend URL ───────────────────────────────────────────────────
# Used in signed-PDF verification QR codes and document invitation emails.
DOCS_BASE_URL=http://localhost:4002

# ─── Mailer ───────────────────────────────────────────────────────────────────
# SMTP settings used for document invitation emails.
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USER=your_smtp_username
MAIL_PASS=your_smtp_password
MAIL_FROM="Gracon Documents <no-reply@example.com>"
