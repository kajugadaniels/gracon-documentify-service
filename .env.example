# documents environment - managed by secret ownership cleanup.
# Keep this file key-compatible with the sibling .env files in this project.

# App
APP_PORT=3005
APP_ENV=development

# Runtime database
# Runtime access only. api/database owns migrations and seeds.
# Database role: gracon_documents_app
# Generate this role password with: node -e "console.log(require('crypto').randomBytes(24).toString('base64url'))"
# Deployment secret source: DOCUMENTS_DATABASE_URL
DATABASE_URL=postgresql://gracon_documents_app:password@host/dbname?sslmode=require

# Shared user JWT
# Must match api/auth JWT_SECRET.
# Deployment secret source: PLATFORM_USER_JWT_SECRET
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=

# Shared identity encryption
# Must match api/auth ENCRYPTION_SECRET.
# Deployment secret source: PLATFORM_IDENTITY_ENCRYPTION_SECRET
# Generate with: node -e "console.log(require('crypto').randomBytes(16).toString('hex'))"
ENCRYPTION_SECRET=

# AWS S3
# Deployment secret source: PLATFORM_AWS_REGION
AWS_REGION=us-east-1
# Deployment secret source: PLATFORM_AWS_ACCESS_KEY_ID
AWS_ACCESS_KEY_ID=
# Deployment secret source: PLATFORM_AWS_SECRET_ACCESS_KEY
AWS_SECRET_ACCESS_KEY=
# Deployment secret source: PLATFORM_AWS_S3_BUCKET_NAME
AWS_S3_BUCKET_NAME=

# Signature service
# Deployment secret source: SIGNATURE_ADMIN_BRIDGE_URL
SIGNATURE_SERVICE_URL=http://localhost:3002

# Document settings
MAX_CONTENT_SIZE_BYTES=10485760
MAX_VERSIONS_PER_DOCUMENT=50
VERSION_RETENTION_DAYS=90

# Editor images
# Deployment secret source: DOCUMENTS_CLOUDINARY_CLOUD_NAME
CLOUDINARY_CLOUD_NAME=
# Deployment secret source: DOCUMENTS_CLOUDINARY_API_KEY
CLOUDINARY_API_KEY=
# Deployment secret source: DOCUMENTS_CLOUDINARY_API_SECRET
CLOUDINARY_API_SECRET=
CLOUDINARY_EDITOR_IMAGES_FOLDER=document-editor-images
DOCUMENTS_API_PUBLIC_URL=http://localhost:3005/api/v1
EDITOR_IMAGE_MAX_SIZE_BYTES=8388608
EDITOR_IMAGE_TOKEN_TTL_SECONDS=2592000

# Frontend and CORS
FRONTEND_URL=http://localhost:4000
FRONTEND_URLS=http://localhost:4000
DOCS_BASE_URL=http://localhost:4002

# Mailer
# Deployment secret source: PLATFORM_SMTP_HOST
MAIL_HOST=
# Deployment secret source: PLATFORM_SMTP_PORT
MAIL_PORT=587
# Deployment secret source: PLATFORM_SMTP_USER
MAIL_USER=
# Deployment secret source: PLATFORM_SMTP_PASS
MAIL_PASS=
MAIL_FROM=
