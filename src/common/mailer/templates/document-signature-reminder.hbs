<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Document Signature Required</title>
</head>
<body style="margin:0;padding:0;background:#f6f4fb;font-family:Arial,sans-serif;color:#1b1733;">
  <table role="presentation" width="100%" cellpadding="0" cellspacing="0" style="background:#f6f4fb;padding:32px 16px;">
    <tr>
      <td align="center">
        <table role="presentation" width="100%" cellpadding="0" cellspacing="0" style="max-width:560px;background:#ffffff;border-radius:20px;overflow:hidden;box-shadow:0 16px 48px rgba(19,12,48,0.08);">
          <tr>
            <td style="padding:32px 32px 20px;border-bottom:1px solid rgba(22,16,58,0.08);">
              <div style="display:inline-block;padding:6px 12px;border-radius:999px;background:#fff7ed;color:#c2410c;font-size:12px;font-weight:700;letter-spacing:0.08em;text-transform:uppercase;">
                Signature Required
              </div>
              <h1 style="margin:18px 0 10px;font-size:28px;line-height:1.2;color:#16103a;">
                Please sign the document
              </h1>
              <p style="margin:0;font-size:15px;line-height:1.7;color:#4c4566;">
                Hello {{recipientName}}, {{senderName}} is waiting for your signature on
                <strong style="color:#16103a;">{{documentTitle}}</strong>.
              </p>
            </td>
          </tr>

          <tr>
            <td style="padding:28px 32px 12px;">
              <a
                href="{{signUrl}}"
                style="display:inline-block;padding:14px 20px;border-radius:14px;background:#16103a;color:#ffffff;text-decoration:none;font-size:15px;font-weight:700;"
              >
                Open document and sign
              </a>
            </td>
          </tr>

          <tr>
            <td style="padding:0 32px 32px;">
              <p style="margin:0 0 12px;font-size:13px;line-height:1.7;color:#5e5779;">
                You must sign in with your verified account before signing. The email does not include document content or certificate details.
              </p>
              <p style="margin:0;font-size:12px;line-height:1.7;color:#8b84a5;">
                If you did not expect this reminder, contact {{supportEmail}}.
              </p>
            </td>
          </tr>
        </table>
      </td>
    </tr>
  </table>
</body>
</html>
